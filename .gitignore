# ──────────────────────────────────────
# Omnisage .gitignore
# ──────────────────────────────────────

# ── Node / Frontend ──
node_modules/
dist/
.node/
*.tgz

# ── Python / Backend ──
__pycache__/
*.pyc
*.pyo
*.pyd
backend/venv/
backend/uploads/
*.egg-info/
.eggs/

# ── Database ──
*.db
*.sqlite3

# ── OS / IDE ──
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ── Environment / Secrets ──
.env
.env.*
!.env.example

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build Artifacts ──
build/
*.tar.gz
*.zip

# ── Installers ──
*.exe
*.msi
*.dmg

# ── Coverage / Testing ──
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
